# ---- Blockchain ----
BASE_SEPOLIA_RPC_URL=https://sepolia.base.org
SPONSOR_PRIVATE_KEY=0x...
COMMUNITY_PRIVATE_KEY=0x...
SPONSOR_WALLET_ADDRESS=0x...
COMMUNITY_WALLET_ADDRESS=0x...

# ---- Deployed Contract Addresses (fill after deploy.ts) ----
INTENT_REGISTRY_ADDRESS=
AD_ESCROW_ADDRESS=

# ---- ERC-8004 Agent IDs (fill after registerAgents.ts) ----
SPONSOR_ERC8004_AGENT_ID=
COMMUNITY_ERC8004_AGENT_ID=
SPONSOR_AGENT_CARD_URI=ipfs://QmSponsorCard
COMMUNITY_AGENT_CARD_URI=ipfs://QmCommunityCard

# ---- Google AI Studio ----
GOOGLE_API_KEY=

# ---- OpenClaw / Z.ai GLM ----
ADSOURCING_OPENCLAW_MODEL=zai/glm-5.1
OPENCLAW_MODEL=zai/glm-5.1
# Optional on VPS: point dashboard OpenClaw runs at a real installed binary.
# Without this, the dashboard falls back to `npx -y openclaw ...`.
OPENCLAW_BIN=/usr/local/bin/openclaw
ZAI_API_KEY=
ZHIPU_API_KEY=
GLM_API_KEY=

# ---- Reputation Settings ----
# Demo fallback only. For live mode, set this to false.
USE_MOCK_REPUTATION=true
# ---- Sponsor Resources Integrations ----
MEM9_API_KEY=
MEM9_API_URL=https://api.mem9.ai
MEM9_ENABLED=true
MEM9_TIMEOUT_MS=8000
MEM9_SEARCH_TIMEOUT_MS=15000
REPLIZ_KEY=AGENTHONCLAW
DOKU_CLIENT_ID=
DOKU_API_KEY=
DOKU_AUTHORIZATION=
DOKU_MODE=sandbox
DOKU_MCP_ENDPOINT=https://api-sandbox.doku.com/doku-mcp-server/mcp
DOKU_CHECKOUT_ENDPOINT=mcp:create_doku_direct_checkout
DOKU_ENABLE_CHECKOUT=false
DOKU_REQUIRED=false
DOKU_TIMEOUT_MS=10000
DOKU_IDR_PER_USD=16000
DOKU_CUSTOMER_EMAIL=sponsor@adsourcing.local
DOKU_CUSTOMER_NAME=AdSourcing Sponsor Agent
DOKU_CUSTOMER_PHONE=+6281234567890
# ---- USDC (Base Sepolia testnet USDC) ----
USDC_CONTRACT_ADDRESS=0x036CbD53842c5426634e7929541eC2318f3dCF7e

# ---- Discord ----
COMMUNITY_DISCORD_BOT_TOKEN=
SPONSOR_DISCORD_BOT_TOKEN=
COMMUNITY_DISCORD_BOT_USER_ID=
DEMO_DISCORD_GUILD_ID=
DEMO_DISCORD_CHANNEL_ID=
COMMUNITY_MEMBER_COUNT=847

# ---- Demo Settings ----
DISPUTE_WINDOW_SECONDS=60
DEMO_USE_LLM=false
AUTONOMOUS_LOOP_ITERATIONS=1
AUTONOMOUS_LOOP_INTERVAL_MS=15000

# ---- Agenthon Local Mode ----
# Middle-ground demo: real local contracts and token transfers, no testnet funds needed.
# Set to false/omit if you want to require real Discord bot delivery.
LOCAL_RPC_URL=http://127.0.0.1:8545
AGENTHON_ALLOW_LOCAL_DELIVERY=true
AGENTHON_USE_LLM=false

# ---- Live Mode ----
# live:preflight refuses to pass unless real contracts exist at the configured addresses,
# wallets have Base Sepolia ETH, sponsor has testnet USDC, Discord is configured,
# ERC-8004 agent IDs are present, and USE_MOCK_REPUTATION=false.
LIVE_STRICT=true
INTENT_TTL_SECONDS=3600
SPONSOR_BUDGET_USDC=400
SPONSOR_CONTENT_POLICY=Web3 and AI products only. No gambling, no scams, no guaranteed returns.
SPONSOR_CONTENT_POLICY_URI=inline://sponsor-content-policy
SPONSOR_AD_COPY=AdSourcing live test: autonomous agent sponsorship with escrowed payment and proof receipt.
SPONSOR_AD_COPY_URI=
SPONSOR_CAMPAIGN_NAME=AdSourcing Live Campaign
COMMUNITY_CONTENT_RULES=no gambling; no scams; no adult content; no guaranteed returns

# ---- Agent Mandates ----
SPONSOR_MAX_PRICE_USDC=40
SPONSOR_MIN_MEMBERS=300
SPONSOR_MIN_COUNTERPARTY_SCORE=70
COMMUNITY_PRICE_FLOOR_USDC=25
COMMUNITY_MIN_SPONSOR_SCORE=70
COMMUNITY_MAX_ADS_PER_DAY=3
