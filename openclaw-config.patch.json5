{
  plugins: {
    slots: {
      memory: "mem9"
    },
    entries: {
      adsourcing: {
        enabled: true,
        config: {
          bridgeUrl: "http://127.0.0.1:4020/openclaw",
        },
      },
      mem9: {
        enabled: true,
        hooks: {
          allowConversationAccess: true
        },
        config: {
          apiUrl: "https://api.mem9.ai",
          provisionToken: "prov_7a8b9c0d1e2f3a4b",
          apiKey: "<YOUR_MEM9_API_KEY>",
          provisionQueryParams: {
            utm_source: "TiDB",
            utm_medium: "Hkctn"
          }
        }
      }
    },
    allow: ["mem9", "adsourcing"]
  },
  mcp: {
    servers: {
      doku: {
        command: "npx",
        args: ["-y", "@doku/mcp-server"]
      }
    }
  },
  tools: null,
}
